headers =
compilerOpts = -ffreestanding
---
#include <stdint.h>

static inline uint32_t mmio_read32(unsigned long addr) {
    return *((volatile uint32_t*)addr);
}

static inline void mmio_write32(unsigned long addr, uint32_t value) {
    *((volatile uint32_t*)addr) = value;
}

static inline void raw_fill32(unsigned long addr, uint32_t value, unsigned long count) {
    uint32_t *p = (uint32_t*)addr;

    for (unsigned long i = 0; i < count; i++)
        p[i] = value;
}

static inline uint8_t raw_read8(unsigned long addr) {
    return *((volatile uint8_t*)addr);
}

static inline uint16_t raw_read16(unsigned long addr) {
    return *((volatile uint16_t*)addr);
}

static inline uint64_t raw_read64(unsigned long addr) {
    return *((volatile uint64_t*)addr);
}

static inline void raw_write8(unsigned long addr, uint8_t value) {
    *((volatile uint8_t*)addr) = value;
}

static inline void raw_write16(unsigned long addr, uint16_t value) {
    *((volatile uint16_t*)addr) = value;
}

static inline void raw_write64(unsigned long addr, uint64_t value) {
    *((volatile uint64_t*)addr) = value;
}

static inline uint64_t boot_fdt_base(void) {
    extern uint64_t kurtos_boot_fdt;
    return kurtos_boot_fdt;
}

static inline uint64_t kernel_heap_start(void) {
    extern uint8_t __heap_start[];
    return (uint64_t)__heap_start;
}

static inline uint64_t kernel_heap_end(void) {
    extern uint8_t __heap_end[];
    return (uint64_t)__heap_end;
}

static inline uint64_t arm_cntpct_el0(void) {
    uint64_t value;
    __asm__ volatile("mrs %0, cntpct_el0" : "=r"(value));
    return value;
}

static inline uint64_t arm_cntfrq_el0(void) {
    uint64_t value;
    __asm__ volatile("mrs %0, cntfrq_el0" : "=r"(value));
    return value;
}
